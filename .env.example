# Ollama
OLLAMA_DATASET_MODEL=gemma4:e4b
OLLAMA_TIMEOUT_SECS=300
OLLAMA_MAX_RETRIES=3
OLLAMA_RETRY_BACKOFF_SECS=2.0
OLLAMA_JUDGE_MODEL=gemma4:e4b
OLLAMA_EMBEDDING_MODEL=embeddinggemma:latest

# Dataset generation
DATASET_LANGUAGE=es
DATASET_RETRIEVAL=lexical
DATASET_CHUNK_SIZE=3500
DATASET_CHUNK_OVERLAP=350
DATASET_NUM_TOPICS=8
DATASET_QUESTIONS_PER_TOPIC=6
DATASET_SPLIT=0.8,0.1,0.1
DATASET_TEMPERATURE=0.2
DATASET_SEED=42
DATASET_MAX_DOC_CONTEXT_CHARS=110000
DATASET_MAX_TOPIC_CONTEXT_CHARS=24000
DATASET_JUDGE=off

# Logging
DATASET_LOG_LEVEL=INFO
